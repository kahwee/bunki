<!DOCTYPE html>
  <html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ site.title }}{% endblock %}</title>
    <meta name="description" content="{% block description %}{{ site.description }}{% endblock %}">

    {# Canonical URL #}
    <link rel="canonical" href="{% block canonical %}{{ site.baseUrl }}/{% endblock %}">

    {# Pagination link tags #}
    {% block pagination_links %}{% endblock %}

    {# Noindex for low-value paginated pages #}
    {% if noindex %}
    <meta name="robots" content="noindex, follow">
    {% endif %}

    {# Open Graph meta tags #}
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:title" content="{% block og_title %}{{ site.title }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ site.description }}{% endblock %}">
    <meta property="og:url" content="{% block og_url %}{{ site.baseUrl }}/{% endblock %}">
    <meta property="og:site_name" content="{{ site.title }}">

    {# Twitter Card meta tags #}
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{% block twitter_title %}{{ site.title }}{% endblock %}">
    <meta name="twitter:description" content="{% block twitter_description %}{{ site.description }}{% endblock %}">

    <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS Feed" href="/feed.xml">
    <link rel="stylesheet" href="/css/style.css">
    {% if site.googleAnalyticsId %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.googleAnalyticsId }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ site.googleAnalyticsId }}');
    </script>
    {% endif %}
    {% block head %}{% endblock %}
    {% if jsonLd %}
    {{ jsonLd | safe }}
    {% endif %}
  </head>
  <body>
    <header>
      <div class="container">
        <h1><a href="/">{{ site.title }}</a></h1>
        <nav>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/tags/">Tags</a></li>
            <li><a href="/map/">Map</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="container">
      {% block content %}{% endblock %}
    </main>

    <footer>
      <div class="container">
        <p>&copy; {{ "now" | date("YYYY") }} {{ site.title }}</p>
      </div>
    </footer>

    {% block scripts %}{% endblock %}
  </body>
  </html>